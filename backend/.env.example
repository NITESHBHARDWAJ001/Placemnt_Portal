FLASK_ENV=development
SECRET_KEY=change-me-super-secret
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7
CORS_ORIGINS=http://localhost:5173
UPLOAD_FOLDER=uploads/resumes
EXPORT_FOLDER=uploads/exports
MAX_CONTENT_LENGTH_MB=5
DEFAULT_ADMIN_EMAIL=admin@placement.com
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_NAME=Portal Administrator

# ---- Redis + Celery ----
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CACHE_DEFAULT_TTL_SECONDS=120

# ---- SMTP ----
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=
ADMIN_REMINDER_WINDOW_DAYS=2
